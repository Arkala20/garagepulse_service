# ============================================
# GaragePulse Environment Configuration
# Copy this file to .env and update values
# ============================================

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_NAME=GaragePulse
APP_ENV=development
APP_DEBUG=True
APP_VERSION=1.0.0

# --------------------------------------------
# Database Configuration (MySQL)


DB_HOST=localhost
DB_PORT=3306
DB_NAME=garagepulse
DB_USER=root
DB_PASSWORD=Arkala@2001
LOG_LEVEL=INFO

# --------------------------------------------
# Security Settings
# --------------------------------------------
BCRYPT_ROUNDS=12

# Secret key for tokens (password reset, etc.)
SECRET_KEY=change_this_to_a_secure_random_string

# Token expiration (minutes)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# --------------------------------------------
# Invoice / Business Settings
# --------------------------------------------
DEFAULT_TAX_RATE=8.5
CURRENCY=USD

# --------------------------------------------
# Notification Settings (Future Ready)
# --------------------------------------------
EMAIL_ENABLED=False
SMS_ENABLED=False

# Example placeholders for future integrations
EMAIL_PROVIDER=
SMS_PROVIDER=

# --------------------------------------------
# Feature Flags
# --------------------------------------------
ENABLE_REPORTS=False
ENABLE_USER_MANAGEMENT=False